{
  "name": "loan-approval-system",
  "version": "1.0.0",
  "description": "A comprehensive AI-powered loan approval prediction system leveraging Human Development Index (HDI) metrics and machine learning for financial risk assessment",
  "main": "dist/server/index.js",
  "scripts": {
    "start": "node dist/server/index.js",
    "dev": "nodemon --watch src -e ts,json --exec ts-node src/server/index.ts",
    "build": "tsc && node copyAssets.js",
    "test": "jest",
    "lint": "eslint src/",
    "format": "prettier --write src/",
    "seed": "ts-node src/scripts/seedDatabase.ts"
  },
  "keywords": ["loan", "approval", "ml", "machine-learning", "fintech", "ai", "hd", "hdi"],
  "author": "Your Name",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "mongoose": "^7.5.0",
    "cors": "^2.8.5",
    "helmet": "^7.0.0",
    "compression": "^1.7.4",
    "dotenv": "^16.3.1",
    "express-rate-limit": "^6.7.0",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "axios": "^1.5.0",
    "csv-parser": "^3.0.0",
    "multer": "^1.4.5-lts.1",
    "sharp": "^0.32.6",
    "node-cron": "^3.0.0",
    "puppeteer": "^21.5.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "typescript": "^5.2.2",
    "ts-node": "^10.9.1",
    "nodemon": "^3.0.1",
    "jest": "^29.7.0",
    "@types/node": "^20.8.0",
    "@types/express": "^4.17.18",
    "@types/cors": "^2.8.5",
    "@types/compression": "^1.7.5",
    "@types/bcryptjs": "^2.4.4",
    "@types/jsonwebtoken": "^9.0.3",
    "@types/multer": "^1.4.7",
    "eslint": "^8.52.0",
    "prettier": "^3.0.3",
    "husky": "^8.0.3",
    "lint-staged": "^15.0.2",
    "rimraf": "^5.0.1"
  },
  "lint-staged": {
    "src/**/*.{ts,js}": ["eslint --fix", "prettier --write"]
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  }
}
