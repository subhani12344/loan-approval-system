# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/portfolio?schema=public"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-super-secret-key-change-in-production-min-32-chars"

# OAuth Providers (optional)
GITHUB_ID=""
GITHUB_SECRET=""
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# File Storage (S3/R2 compatible)
S3_ENDPOINT="https://your-account.r2.cloudflarestorage.com"
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_BUCKET="portfolio-uploads"
S3_PUBLIC_URL="https://pub-xxx.r2.dev"

# Resume Parser Service
PARSER_SERVICE_URL="http://localhost:8000"
PARSER_API_KEY=""

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"